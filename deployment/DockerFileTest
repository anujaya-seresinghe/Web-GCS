FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    gcc \
    g++ \
    gdb \
    net-tools \
    iputils-ping \
    curl \
    python3 \
    python3-pip \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*


RUN pip3 install pymavlink

WORKDIR /workspace
COPY ./tests/send_coords.py .
COPY ./tests/mavlink_server.c .
COPY libraries/mavlink ./mavlink


RUN gcc mavlink_server.c -o mavlink_server \
    -I./mavlink 



CMD ["./mavlink_server"]